{
  "uid": "tcc-comparativo",
  "title": "TCC - Comparativo de Cenários (M1-M5)",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "tags": ["tcc", "comparativo", "k6"],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "type": "query",
        "datasource": "Prometheus",
        "definition": "label_values(k6_http_reqs_total, scenario)",
        "query": "label_values(k6_http_reqs_total, scenario)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1
      },
      {
        "name": "run_id",
        "type": "query",
        "datasource": "Prometheus",
        "definition": "label_values(k6_http_reqs_total, run_id)",
        "query": "label_values(k6_http_reqs_total, run_id)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "M1 — Latência de Replicação",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "M1 — Latência de Replicação P95 / P99",
      "description": "Latência ponta-a-ponta de replicação por cenário. Pessoa usa timestamps do BD (criadoEm/replicadoEm).",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_replication_latency_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "{{scenario}} p95"
        },
        {
          "refId": "B",
          "expr": "k6_replication_latency_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.99\"}",
          "legendFormat": "{{scenario}} p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "M1 — Latência por Entidade / Ação (P95)",
      "description": "Breakdown de latência por entidade e ação de replicação.",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_replication_latency_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "{{scenario}} {{entity}}/{{action}} → {{target}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "M2 — Throughput",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "M2 — Throughput: Fluxos Completos / s",
      "description": "Taxa de fluxos de negócio completos (pessoa → vínculo → conclusão → diploma) por segundo.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(k6_business_throughput_total{scenario=~\"$scenario\", run_id=~\"$run_id\"}[$__rate_interval])",
          "legendFormat": "{{scenario}} fluxos/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "M2 — Throughput: Replicações / s",
      "description": "Taxa de replicações bem-sucedidas por segundo.",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(k6_replication_success_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"}[$__rate_interval])",
          "legendFormat": "{{scenario}} replicações/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "M3 — Taxa de Erro / M4 — Consistência",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "stat",
      "title": "M3 — Taxa de Erro de Replicação (%)",
      "description": "Percentual de replicações que falharam (timeout ou dados incorretos).",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_replication_failure_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"} / (k6_replication_failure_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"} + k6_replication_success_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"}) * 100",
          "legendFormat": "{{scenario}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "M4 — Consistência (Checks %)",
      "description": "Taxa de asserções check() que passaram — valida campo a campo nos dados replicados.",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_checks{scenario=~\"$scenario\", run_id=~\"$run_id\"}",
          "legendFormat": "{{scenario}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "M5 — Staleness / Apoio",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "M5 — Staleness Window P95 / P99",
      "description": "Janela de inconsistência: tempo entre conclusão no serviço de origem e visibilidade no serviço de destino.",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_staleness_window_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "{{scenario}} p95"
        },
        {
          "refId": "B",
          "expr": "k6_staleness_window_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.99\"}",
          "legendFormat": "{{scenario}} p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Req Duration P95 (por serviço)",
      "description": "Latência HTTP P95 por serviço — métrica de apoio.",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "{{scenario}} {{service}} p95"
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Resumo Comparativo",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Resumo M1-M5 por Cenário (últimos valores)",
      "description": "Tabela comparativa com os últimos valores de cada métrica por cenário.",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "M1 Latencia P95 (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "M1 Latencia P99 (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "M3 Erro (%)" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byName", "options": "M4 Checks (%)" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "M5 Staleness P95 (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "scenario", "desc": false }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "k6_replication_latency_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "M1 Latencia P95 (ms)",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "k6_replication_latency_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.99\"}",
          "legendFormat": "M1 Latencia P99 (ms)",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "expr": "k6_replication_failure_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"} / (k6_replication_failure_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"} + k6_replication_success_total_total{scenario=~\"$scenario\", run_id=~\"$run_id\"}) * 100",
          "legendFormat": "M3 Erro (%)",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "expr": "k6_checks{scenario=~\"$scenario\", run_id=~\"$run_id\"}",
          "legendFormat": "M4 Checks (%)",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "E",
          "expr": "k6_staleness_window_ms{scenario=~\"$scenario\", run_id=~\"$run_id\", quantile=\"0.95\"}",
          "legendFormat": "M5 Staleness P95 (ms)",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
